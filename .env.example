# Mising Archives Environment Variables

# Site Configuration
VITE_SITE_TITLE=Mising Archives
VITE_SITE_DESCRIPTION=A community-led initiative to preserve and share knowledge about Mising culture, tradition, history, and language

# Google Drive API (optional - for future features)
# VITE_GOOGLE_DRIVE_API_KEY=your_api_key_here
# Analytics (optional)
# VITE_ANALYTICS_ID=your_tracking_id

# Note: Copy this file to .env.local and update with your actual values
# For public environment variables, prefix with VITE_
